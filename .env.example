# PostgreSQL from Neon.tech — paste your connection string here
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Generate a long random secret: openssl rand -hex 32
JWT_SECRET="change-this-to-a-long-random-secret"

# Admin panel session secret (different from JWT)
SESSION_SECRET="change-this-to-another-long-random-secret"

# Admin panel login (change before deploying!)
ADMIN_EMAIL="admin@taskpay.com"
ADMIN_PASSWORD="ChangeMe123!"

# Port (Render sets this automatically)
PORT=3000

# Points system
POINTS_PER_DOLLAR=100
MIN_WITHDRAW_POINTS=500
